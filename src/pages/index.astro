---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
  <section class="hero section">
    <div class="container">
      <span class="tag">Portfolio</span>
      <h1>
        <span data-content-html="home.hero.heading">Crafting<br />digital</span><br />
        <em><span data-content="home.hero.accent">experiences</span></em>
      </h1>
      <p class="sub" data-content="home.hero.subtext">Designer & creative director focused on brand, identity, and digital product.</p>
      <div class="cta-row">
        <a href="/work" class="btn btn-accent">View Work</a>
        <a href="/contact" class="btn">Get in Touch</a>
      </div>
    </div>
  </section>

  <section class="section-divider section">
    <div class="container">
      <div class="stats-row">
        <div class="stat">
          <span class="num" data-content="home.stats.stat1_number">8+</span>
          <span class="label" data-content="home.stats.stat1_label">Years Experience</span>
        </div>
        <div class="stat">
          <span class="num" data-content="home.stats.stat2_number">60+</span>
          <span class="label" data-content="home.stats.stat2_label">Projects Delivered</span>
        </div>
        <div class="stat">
          <span class="num" data-content="home.stats.stat3_number">30+</span>
          <span class="label" data-content="home.stats.stat3_label">Happy Clients</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Selected Work</h2>
      <div class="work-grid">
        <a href="/work" class="work-card">
          <div class="work-thumb"></div>
          <div class="work-info">
            <h3>Project Name</h3>
            <span>Branding / Identity</span>
          </div>
        </a>
        <a href="/work" class="work-card">
          <div class="work-thumb"></div>
          <div class="work-info">
            <h3>Project Name</h3>
            <span>Web Design</span>
          </div>
        </a>
        <a href="/work" class="work-card">
          <div class="work-thumb"></div>
          <div class="work-info">
            <h3>Project Name</h3>
            <span>Product Design</span>
          </div>
        </a>
      </div>
      <div style="text-align:center; margin-top: 3rem;">
        <a href="/work" class="btn">See All Work</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero { padding-top: 8rem; }
  .hero h1 { margin-bottom: 1.5rem; }
  .hero em { font-style: italic; color: var(--highlight); }
  .sub { color: var(--muted); max-width: 420px; margin-bottom: 2.5rem; }
  .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 3rem 0;
  }
  .stat { text-align: center; }
  .num { display: block; font-size: 3rem; font-weight: 300; color: var(--highlight); }
  .label { font-size: 0.8rem; color: var(--muted); letter-spacing: 0.05em; }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .work-card { display: block; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; transition: border-color 0.2s; }
  .work-card:hover { border-color: var(--muted); }
  .work-thumb { background: var(--surface); height: 220px; }
  .work-info { padding: 1rem 1.25rem; }
  .work-info span { font-size: 0.75rem; color: var(--muted); }
</style>
