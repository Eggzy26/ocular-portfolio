---
export const prerender = false;
import { supabaseAdmin } from '../../lib/supabase-admin.ts';

// Auth check
const cookie = Astro.request.headers.get('cookie') ?? '';
const authenticated = cookie.includes('admin_session=authenticated');
if (!authenticated) return Astro.redirect('/admin/login');

// Content schema — defines all editable fields per page
const SCHEMA: Record<string, { label: string; sections: Record<string, { label: string; fields: Record<string, { label: string; type: 'text' | 'textarea' }> }> }> = {
  home: {
    label: 'Home',
    sections: {
      hero: {
        label: 'Hero Section',
        fields: {
          heading:  { label: 'Heading (use \\n for new lines)', type: 'textarea' },
          accent:   { label: 'Accent Word (highlighted)', type: 'text' },
          subtext:  { label: 'Subtext', type: 'textarea' },
        },
      },
      stats: {
        label: 'Stats Row',
        fields: {
          stat1_number: { label: 'Stat 1 — Number', type: 'text' },
          stat1_label:  { label: 'Stat 1 — Label', type: 'text' },
          stat2_number: { label: 'Stat 2 — Number', type: 'text' },
          stat2_label:  { label: 'Stat 2 — Label', type: 'text' },
          stat3_number: { label: 'Stat 3 — Number', type: 'text' },
          stat3_label:  { label: 'Stat 3 — Label', type: 'text' },
        },
      },
    },
  },
  about: {
    label: 'About',
    sections: {
      hero: {
        label: 'Intro',
        fields: {
          heading: { label: 'Heading (use \\n for new lines)', type: 'textarea' },
          body1:   { label: 'Paragraph 1', type: 'textarea' },
          body2:   { label: 'Paragraph 2', type: 'textarea' },
        },
      },
    },
  },
  services: {
    label: 'Services',
    sections: {
      hero: {
        label: 'Page Header',
        fields: {
          heading: { label: 'Heading (use \\n for new lines)', type: 'textarea' },
          subtext: { label: 'Subtext', type: 'textarea' },
        },
      },
      card1: { label: 'Service 1', fields: { title: { label: 'Title', type: 'text' }, desc: { label: 'Description', type: 'textarea' } } },
      card2: { label: 'Service 2', fields: { title: { label: 'Title', type: 'text' }, desc: { label: 'Description', type: 'textarea' } } },
      card3: { label: 'Service 3', fields: { title: { label: 'Title', type: 'text' }, desc: { label: 'Description', type: 'textarea' } } },
      card4: { label: 'Service 4', fields: { title: { label: 'Title', type: 'text' }, desc: { label: 'Description', type: 'textarea' } } },
      cta: {
        label: 'CTA Block',
        fields: {
          heading: { label: 'Heading', type: 'text' },
          subtext: { label: 'Subtext', type: 'textarea' },
        },
      },
    },
  },
  contact: {
    label: 'Contact',
    sections: {
      hero: {
        label: 'Page Header',
        fields: {
          heading: { label: 'Heading (use \\n for new lines)', type: 'textarea' },
          subtext: { label: 'Subtext', type: 'textarea' },
        },
      },
      info: {
        label: 'Contact Info',
        fields: {
          email:        { label: 'Email Address', type: 'text' },
          location:     { label: 'Location', type: 'text' },
          availability: { label: 'Availability Status', type: 'text' },
        },
      },
    },
  },
  blog: {
    label: 'Blog',
    sections: {
      hero: {
        label: 'Page Header',
        fields: {
          heading: { label: 'Heading (use \\n for new lines)', type: 'textarea' },
          subtext: { label: 'Subtext', type: 'textarea' },
        },
      },
    },
  },
};

// Handle save
let saved = false;
let saveError = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const entries: { page: string; section: string; field: string; value: string }[] = [];
  for (const [key, val] of form.entries()) {
    const parts = key.split('.');
    if (parts.length === 3) {
      entries.push({ page: parts[0], section: parts[1], field: parts[2], value: String(val) });
    }
  }
  if (entries.length > 0) {
    const { error } = await supabaseAdmin
      .from('content')
      .upsert(entries, { onConflict: 'page,section,field' });
    if (error) saveError = error.message;
    else saved = true;
  }
}

// Fetch current content
const { data: rows } = await supabaseAdmin.from('content').select('*');
const db: Record<string, string> = {};
for (const row of rows ?? []) {
  db[`${row.page}.${row.section}.${row.field}`] = row.value;
}

const activePage = Astro.url.searchParams.get('page') ?? 'home';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Content | Ocular Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="header-left">
        <a href="/" class="logo">Ocular</a>
        <span class="divider">/</span>
        <a href="/admin" class="page-title">Admin</a>
        <span class="divider">/</span>
        <span class="page-title">Content</span>
      </div>
      <div class="header-right">
        <a href="/admin" class="nav-link">Submissions</a>
        <a href="/admin/logout" class="logout">Sign Out</a>
      </div>
    </div>
  </header>

  <div class="layout">
    <!-- Sidebar: page tabs -->
    <aside class="sidebar">
      <p class="sidebar-label">Pages</p>
      {Object.entries(SCHEMA).map(([key, page]) => (
        <a
          href={`/admin/content?page=${key}`}
          class={`sidebar-link${activePage === key ? ' active' : ''}`}
        >
          {page.label}
        </a>
      ))}
      <div class="sidebar-divider"></div>
      <a href="/" target="_blank" class="sidebar-link preview-link">↗ View Site</a>
    </aside>

    <!-- Main: edit form -->
    <main class="main">
      {saved && <div class="alert success">✓ Content saved successfully.</div>}
      {saveError && <div class="alert error">Error: {saveError}</div>}

      {SCHEMA[activePage] && (
        <form method="POST" action={`/admin/content?page=${activePage}`}>
          <div class="page-header">
            <h1>{SCHEMA[activePage].label}</h1>
            <button type="submit" class="save-btn">Save Changes</button>
          </div>

          {Object.entries(SCHEMA[activePage].sections).map(([sectionKey, section]) => (
            <div class="section-card">
              <h2 class="section-title">{section.label}</h2>
              <div class="fields">
                {Object.entries(section.fields).map(([fieldKey, field]) => {
                  const key = `${activePage}.${sectionKey}.${fieldKey}`;
                  const val = db[key] ?? '';
                  return (
                    <div class="field">
                      <label for={key}>{field.label}</label>
                      {field.type === 'textarea' ? (
                        <textarea id={key} name={key} rows={3}>{val}</textarea>
                      ) : (
                        <input type="text" id={key} name={key} value={val} />
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          ))}

          <div class="bottom-save">
            <button type="submit" class="save-btn">Save Changes</button>
          </div>
        </form>
      )}
    </main>
  </div>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0a0a0a; color: #e8e8e8; font-family: 'Inter', sans-serif; font-weight: 300; min-height: 100vh; }

  header { border-bottom: 1px solid #1a1a1a; padding: 1rem 2rem; position: sticky; top: 0; background: rgba(10,10,10,0.95); backdrop-filter: blur(10px); z-index: 10; }
  .header-inner { max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
  .header-left { display: flex; align-items: center; gap: 0.75rem; }
  .header-right { display: flex; align-items: center; gap: 1.5rem; }
  .logo { font-size: 0.9rem; font-weight: 600; color: #c8f04a; text-decoration: none; letter-spacing: 0.05em; }
  .divider { color: #333; }
  .page-title { font-size: 0.9rem; color: #666; text-decoration: none; }
  .page-title:hover { color: #e8e8e8; }
  .nav-link { font-size: 0.8rem; color: #555; text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: #e8e8e8; }
  .logout { font-size: 0.8rem; color: #555; text-decoration: none; transition: color 0.2s; }
  .logout:hover { color: #e8e8e8; }

  .layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 57px); max-width: 1400px; margin: 0 auto; }

  .sidebar { border-right: 1px solid #1a1a1a; padding: 2rem 1.25rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .sidebar-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; color: #444; padding: 0 0.75rem; margin-bottom: 0.5rem; }
  .sidebar-link { display: block; padding: 0.6rem 0.75rem; font-size: 0.85rem; color: #555; text-decoration: none; border-radius: 6px; transition: background 0.15s, color 0.15s; }
  .sidebar-link:hover { background: #111; color: #e8e8e8; }
  .sidebar-link.active { background: #161616; color: #e8e8e8; }
  .sidebar-divider { border-top: 1px solid #1a1a1a; margin: 1rem 0.75rem; }
  .preview-link { color: #444; font-size: 0.8rem; }

  .main { padding: 2.5rem 3rem; }

  .alert { padding: 0.875rem 1.25rem; border-radius: 6px; font-size: 0.85rem; margin-bottom: 1.5rem; }
  .alert.success { background: rgba(200,240,74,0.08); border: 1px solid rgba(200,240,74,0.2); color: #c8f04a; }
  .alert.error { background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.2); color: #ff6b6b; }

  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .page-header h1 { font-size: 1.4rem; font-weight: 400; }

  .section-card { border: 1px solid #1a1a1a; border-radius: 8px; padding: 1.75rem; margin-bottom: 1.25rem; }
  .section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #555; margin-bottom: 1.25rem; }

  .fields { display: flex; flex-direction: column; gap: 1.25rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.75rem; color: #666; }

  input, textarea {
    background: #0f0f0f;
    border: 1px solid #222;
    border-radius: 6px;
    padding: 0.7rem 1rem;
    color: #e8e8e8;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 300;
    transition: border-color 0.2s;
    resize: vertical;
    width: 100%;
  }
  input:focus, textarea:focus { outline: none; border-color: #444; }

  .save-btn {
    background: #c8f04a;
    color: #0a0a0a;
    border: none;
    border-radius: 6px;
    padding: 0.6rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .save-btn:hover { opacity: 0.85; }

  .bottom-save { margin-top: 1.5rem; display: flex; justify-content: flex-end; }
</style>
