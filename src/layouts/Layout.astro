---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Ocular — Portfolio' } = Astro.props;
const nav = [
  { label: 'Home', href: '/' },
  { label: 'Work', href: '/work' },
  { label: 'Services', href: '/services' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
const current = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Ocular</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <nav class="nav-inner">
      <a href="/" class="logo">Ocular</a>
      <ul>
        {nav.map(({ label, href }) => (
          <li>
            <a href={href} class={current === href || (href !== '/' && current.startsWith(href)) ? 'active' : ''}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>&copy; {new Date().getFullYear()} Ocular. All rights reserved.</p>
  </footer>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --border: #222222;
    --text: #e8e8e8;
    --muted: #666666;
    --accent: #f0f0f0;
    --highlight: #c8f04a;
    --max-w: 1100px;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  a { color: inherit; text-decoration: none; }

  header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--highlight);
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.2s;
    letter-spacing: 0.03em;
  }

  nav ul a:hover, nav ul a.active {
    color: var(--text);
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section { padding: 6rem 0; }

  h1 { font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 300; line-height: 1.1; letter-spacing: -0.02em; }
  h2 { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 300; letter-spacing: -0.01em; }
  h3 { font-size: 1.1rem; font-weight: 500; }

  .tag {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--highlight);
    border: 1px solid var(--highlight);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--text);
    border-radius: 999px;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
    background: transparent;
    color: var(--text);
    font-family: inherit;
  }

  .btn:hover { background: var(--text); color: var(--bg); }
  .btn-accent { background: var(--highlight); color: var(--bg); border-color: var(--highlight); }
  .btn-accent:hover { background: transparent; color: var(--highlight); }
</style>
