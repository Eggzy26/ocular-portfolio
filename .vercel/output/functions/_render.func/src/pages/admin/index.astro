---
export const prerender = false;

import { supabaseAdmin } from '../../lib/supabase-admin.ts';

// Auth check
const cookie = Astro.request.headers.get('cookie') ?? '';
const authenticated = cookie.includes('admin_session=authenticated');
if (!authenticated) {
  return Astro.redirect('/admin/login');
}

// Handle actions
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action');
  const id = form.get('id');

  if (action === 'delete' && id) {
    await supabaseAdmin.from('contacts').delete().eq('id', id);
  }

  if (action === 'toggle_read' && id) {
    const { data } = await supabaseAdmin.from('contacts').select('read').eq('id', id).single();
    await supabaseAdmin.from('contacts').update({ read: !data?.read }).eq('id', id);
  }

  return Astro.redirect('/admin');
}

// Fetch contacts
const { data: contacts, error } = await supabaseAdmin
  .from('contacts')
  .select('*')
  .order('created_at', { ascending: false });

const unread = contacts?.filter(c => !c.read).length ?? 0;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | Ocular</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="header-left">
        <a href="/" class="logo">Ocular</a>
        <span class="divider">/</span>
        <span class="page-title">Admin</span>
      </div>
      <a href="/admin/logout" class="logout">Sign Out</a>
    </div>
  </header>

  <main>
    <div class="container">
      <div class="top-row">
        <div>
          <h1>Contact Submissions</h1>
          <p class="sub">{contacts?.length ?? 0} total &nbsp;·&nbsp; {unread} unread</p>
        </div>
      </div>

      {error && <p class="err">Error loading contacts: {error.message}</p>}

      {!contacts?.length ? (
        <div class="empty">
          <p>No submissions yet. Share your contact page and check back.</p>
        </div>
      ) : (
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th></th>
                <th>Name</th>
                <th>Email</th>
                <th>Subject</th>
                <th>Message</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {contacts.map(c => (
                <tr class={!c.read ? 'unread' : ''}>
                  <td>
                    {!c.read && <span class="dot" title="Unread"></span>}
                  </td>
                  <td class="name">{c.name}</td>
                  <td>
                    <a href={`mailto:${c.email}`} class="email-link">{c.email}</a>
                  </td>
                  <td class="subject">{c.subject || '—'}</td>
                  <td class="message-cell">
                    <span class="message-preview" title={c.message}>{c.message}</span>
                  </td>
                  <td class="date">
                    {new Date(c.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </td>
                  <td class="actions">
                    <form method="POST" style="display:inline">
                      <input type="hidden" name="action" value="toggle_read" />
                      <input type="hidden" name="id" value={c.id} />
                      <button type="submit" class="action-btn" title={c.read ? 'Mark unread' : 'Mark read'}>
                        {c.read ? '○' : '●'}
                      </button>
                    </form>
                    <a href={`mailto:${c.email}?subject=Re: ${c.subject || 'Your message'}`} class="action-btn reply-btn" title="Reply">↩</a>
                    <form method="POST" style="display:inline" onsubmit="return confirm('Delete this submission?')">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={c.id} />
                      <button type="submit" class="action-btn delete-btn" title="Delete">✕</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </main>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #0a0a0a;
    color: #e8e8e8;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    min-height: 100vh;
  }

  header {
    border-bottom: 1px solid #1a1a1a;
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    background: rgba(10,10,10,0.9);
    backdrop-filter: blur(10px);
    z-index: 10;
  }

  .header-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
  .header-left { display: flex; align-items: center; gap: 0.75rem; }
  .logo { font-size: 0.9rem; font-weight: 600; color: #c8f04a; text-decoration: none; letter-spacing: 0.05em; }
  .divider { color: #333; }
  .page-title { font-size: 0.9rem; color: #666; }
  .logout { font-size: 0.8rem; color: #555; text-decoration: none; transition: color 0.2s; }
  .logout:hover { color: #e8e8e8; }

  .container { max-width: 1200px; margin: 0 auto; padding: 2.5rem 2rem; }

  .top-row { margin-bottom: 2rem; }
  h1 { font-size: 1.5rem; font-weight: 400; }
  .sub { color: #555; font-size: 0.85rem; margin-top: 0.3rem; }

  .err { color: #ff6b6b; margin-bottom: 1rem; }

  .empty {
    border: 1px solid #1a1a1a;
    border-radius: 8px;
    padding: 4rem;
    text-align: center;
    color: #444;
  }

  .table-wrap { overflow-x: auto; border: 1px solid #1a1a1a; border-radius: 8px; }

  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }

  thead { background: #0f0f0f; }
  th { padding: 0.75rem 1rem; text-align: left; font-size: 0.7rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: #444; border-bottom: 1px solid #1a1a1a; }

  td { padding: 1rem; border-bottom: 1px solid #111; vertical-align: top; }
  tr:last-child td { border-bottom: none; }

  tr.unread { background: rgba(200, 240, 74, 0.03); }
  tr:hover { background: #0f0f0f; }

  .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #c8f04a; margin-top: 4px; }

  .name { font-weight: 500; white-space: nowrap; color: #e8e8e8; }
  .email-link { color: #888; text-decoration: none; transition: color 0.2s; }
  .email-link:hover { color: #c8f04a; }
  .subject { color: #666; }

  .message-cell { max-width: 280px; }
  .message-preview {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: #555;
    line-height: 1.4;
    cursor: help;
  }

  .date { white-space: nowrap; color: #444; font-size: 0.8rem; }

  .actions { white-space: nowrap; display: flex; gap: 0.4rem; align-items: center; }
  .action-btn {
    background: none;
    border: 1px solid #1a1a1a;
    border-radius: 4px;
    color: #555;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.75rem;
    padding: 0.3rem 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .action-btn:hover { border-color: #444; color: #e8e8e8; }
  .reply-btn:hover { border-color: #c8f04a; color: #c8f04a; }
  .delete-btn:hover { border-color: #ff6b6b; color: #ff6b6b; }
</style>
